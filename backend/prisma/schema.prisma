generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tokens Int @default(100)
  level  Int @default(1)
  xp     Int @default(0)

  position  Json   @default("{\"x\": 0, \"y\": 0, \"z\": 0}")
  worldZone String @default("start_zone")

  inventory       InventoryItem[]
  ownedLand       Land[]
  ownedBuildings  Building[]
  rentedRobots    RobotRental[]
  marketListings  MarketListing[]
  marketPurchases MarketPurchase[]
  quests          PlayerQuest[]
  transactions    Transaction[]
}

model Resource {
  id        String @id @default(uuid())
  name      String @unique
  nameHe    String
  icon      String
  basePrice Int
  maxStack  Int    @default(100)

  inventoryItems InventoryItem[]
  marketListings MarketListing[]
}

model InventoryItem {
  id         String   @id @default(uuid())
  playerId   String
  resourceId String
  quantity   Int      @default(0)
  updatedAt  DateTime @updatedAt

  player   Player   @relation(fields: [playerId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([playerId, resourceId])
}

model Land {
  id        String   @id @default(uuid())
  ownerId   String
  zone      String
  coordX    Int
  coordY    Int
  size      String   @default("small")
  type      String   @default("empty")
  createdAt DateTime @default(now())

  owner     Player     @relation(fields: [ownerId], references: [id])
  buildings Building[]
  farmPlots FarmPlot[]

  @@unique([coordX, coordY, zone])
}

model Building {
  id      String   @id @default(uuid())
  ownerId String
  landId  String
  type    String
  model   String
  level   Int      @default(1)
  builtAt DateTime @default(now())

  owner Player @relation(fields: [ownerId], references: [id])
  land  Land   @relation(fields: [landId], references: [id])
}

model FarmPlot {
  id        String    @id @default(uuid())
  landId    String
  cropType  String?
  stage     String    @default("empty")
  plantedAt DateTime?
  harvestAt DateTime?
  quantity  Int       @default(0)

  land Land @relation(fields: [landId], references: [id])
}

model Robot {
  id          String  @id @default(uuid())
  name        String  @unique
  nameHe      String
  type        String
  model       String
  description String
  rentalPrice Int
  available   Boolean @default(true)

  rentals RobotRental[]
}

model RobotRental {
  id        String   @id @default(uuid())
  robotId   String
  playerId  String
  startedAt DateTime @default(now())
  endsAt    DateTime
  status    String   @default("active")

  robot  Robot  @relation(fields: [robotId], references: [id])
  player Player @relation(fields: [playerId], references: [id])
}

model MarketListing {
  id         String   @id @default(uuid())
  sellerId   String
  resourceId String
  quantity   Int
  price      Int
  createdAt  DateTime @default(now())
  status     String   @default("active")

  seller    Player           @relation(fields: [sellerId], references: [id])
  resource  Resource         @relation(fields: [resourceId], references: [id])
  purchases MarketPurchase[]
}

model MarketPurchase {
  id        String   @id @default(uuid())
  listingId String
  buyerId   String
  quantity  Int
  totalCost Int
  boughtAt  DateTime @default(now())

  listing MarketListing @relation(fields: [listingId], references: [id])
  buyer   Player        @relation(fields: [buyerId], references: [id])
}

model Quest {
  id           String @id @default(uuid())
  name         String @unique
  nameHe       String
  description  String
  type         String
  reward       Int
  xpReward     Int
  requirements Json

  playerQuests PlayerQuest[]
}

model PlayerQuest {
  id          String    @id @default(uuid())
  playerId    String
  questId     String
  status      String    @default("active")
  progress    Json      @default("{}")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  player Player @relation(fields: [playerId], references: [id])
  quest  Quest  @relation(fields: [questId], references: [id])
}

model Transaction {
  id        String   @id @default(uuid())
  playerId  String
  type      String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])
}
